# ChatCoreLab Trading Agent — Variáveis de Ambiente
# Copia este ficheiro para .env (nunca versionar .env)
# No Claude Desktop: injetar estas variáveis em Cloud Environment

# ── Alpaca Brokerage ────────────────────────────────────────────────────────
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ALPACA_PAPER=false   # descomenta apenas para live trading (após 30 dias paper)

# ── Perplexity Research ─────────────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ClickUp Alerts ──────────────────────────────────────────────────────────
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxx
CLICKUP_LIST_ID=xxxxxxxxx   # ID da List onde os alertas serão criados

# ── Mock Mode (sem chaves reais) ────────────────────────────────────────────
# ALPACA_PAPER_MOCK=true   # descomenta para testar sem credenciais
